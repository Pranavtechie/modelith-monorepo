{
	"name": "backend",
	"type": "module",
	"main": "./src/index.ts",
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"build-elysia": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server-executable-file src/index.ts",
		"start:prod": "bun run build-elysia && pm2 start ecosystem.config.js",
		"typecheck": "tsc"
	},
	"devDependencies": {
		"@repo/typescript-config": "workspace:*",
		"@types/bun": "^1.1.10",
		"bun-types": "^1.1.29",
		"typescript": "5"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.1.1",
		"add": "^2.0.6",
		"elysia": "1"
	}
}
